{
  "name": "baton",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "lint:js": "wp-scripts lint-js src/",
    "lint:css": "wp-scripts lint-css",
    "check": "npm run check:static",
    "check:static": "composer check && npm run lint:js",
    "release:org": "bash scripts/build-wordpress-org-release.sh",
    "wp-env": "wp-env",
    "test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/baton -- composer test"
  },
  "devDependencies": {
    "@wordpress/env": "^10.28.0",
    "@wordpress/scripts": "^30.7.0"
  }
}
